From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Hyprland RPM maintainers <jnetto@mineiro.io>
Date: Sun, 10 May 2026 00:00:00 +0000
Subject: [PATCH] cmake: allow Lua 5.4 on Fedora 43/44

Fedora 43 and Fedora 44 currently ship Lua 5.4, while rawhide already has
Lua 5.5. Accept both for the 0.55 package path so the same spec remains
buildable across the supported chroots.
---
 CMakeLists.txt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index c694a8f..6eb5764 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -274,7 +274,7 @@ pkg_check_modules(
   lcms2
 )
 
-pkg_search_module(LUA REQUIRED IMPORTED_TARGET GLOBAL lua55 lua5.5 lua-55 lua-5.5 lua>=5.5 lua<5.6)
+pkg_search_module(LUA REQUIRED IMPORTED_TARGET GLOBAL lua55 lua5.5 lua-55 lua-5.5 lua>=5.4 lua<5.6)
 
 find_package(hyprwayland-scanner 0.3.10 REQUIRED)
 
-- 
2.50.0
