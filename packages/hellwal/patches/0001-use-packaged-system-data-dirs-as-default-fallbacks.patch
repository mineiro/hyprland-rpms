+char *load_theme_from_dir(const char *dir_path, const char *themename)
+{
+    if (dir_path == NULL || themename == NULL)
+        return NULL;
+
+    DIR *dir = opendir(dir_path);
+    if (dir == NULL)
+        return NULL;
+
+    struct dirent *entry;
+    while ((entry = readdir(dir)) != NULL)
+    {
+        if (strcmp(entry->d_name, themename) != 0)
+            continue;
+
+        size_t path_len = strlen(dir_path) + strlen(entry->d_name) + 2;
+        char *path = malloc(path_len);
+        if (path == NULL) {
+            perror("Failed to allocate memory for file path");
+            closedir(dir);
+            return NULL;
+        }
+
+        snprintf(path, path_len, "%s/%s", dir_path, entry->d_name);
+        char *theme = load_file(path);
+        free(path);
+        if (theme != NULL)
+        {
+            closedir(dir);
+            return theme;
+        }
+    }
+
+    closedir(dir);
+    return NULL;
+}
