+int write_term_sequences(int fd, const char *buffer, size_t len)
+{
+    size_t total = 0;
+
+    while (total < len)
+    {
+        ssize_t written = write(fd, buffer + total, len - total);
+        if (written > 0)
+        {
+            total += (size_t)written;
+            continue;
+        }
+
+        if (written < 0 && errno == EINTR)
+            continue;
+
+        if (written < 0 && (errno == EAGAIN || errno == EWOULDBLOCK ||
+                            errno == EIO || errno == ENXIO))
+            return 0;
+
+        return 0;
+    }
+
+    return 1;
+}
