From ad17133b548353a7b3f4d8e4ff2836fbde868255 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Sun, 8 Mar 2026 02:45:54 -0300
Subject: [PATCH] meson: preload gtk4-layer-shell by soname

---
 meson.build | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/meson.build b/meson.build
index 29ea111..c9f8227 100644
--- a/meson.build
+++ b/meson.build
@@ -23,7 +23,7 @@ custom_target(
     '-o', meson.project_build_root() / 'ags',
     '-ldflags',
     '-X main.gtk4LayerShell='
-    + dependency('gtk4-layer-shell-0').get_variable('libdir') / 'libgtk4-layer-shell.so'
+    +  'libgtk4-layer-shell.so.0'
     + ' -X main.agsJsPackage='
     + pkgdatadir / 'js'
     + ' -X main.gjs='
